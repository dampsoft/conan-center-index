 <tim.brueggemann@dampsoft.de>
Date: Mon, 20 Apr 2026 16:06:54 +0200
Subject: [PATCH] cmake usage

---
 CMakeLists.txt      | 2 +-
 glib/CMakeLists.txt | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 39b36d7a..bba3aa45 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -160,7 +160,7 @@ endif()
 
 macro(find_soft_mandatory_package _enable_option _package_name _package_version)
   if(${_enable_option})
-    find_package(${_package_name} ${_package_version})
+    find_package(${_package_name} CONFIG ${_package_version} REQUIRED)
     if(NOT ${_package_name}_FOUND)
       MESSAGE(FATAL_ERROR "Could not find the ${_package_version} version of ${_package_name}. If you're not interested in the features it provides set the cmake ${_enable_option} option to OFF")
     endif()
diff --git a/glib/CMakeLists.txt b/glib/CMakeLists.txt
index 94993810..3ca3df34 100644
--- a/glib/CMakeLists.txt
+++ b/glib/CMakeLists.txt
@@ -95,7 +95,7 @@ if(MINGW AND BUILD_SHARED_LIBS)
     get_target_property(POPPLER_GLIB_SOVERSION poppler-glib SOVERSION)
     set_target_properties(poppler-glib PROPERTIES SUFFIX "-${POPPLER_GLIB_SOVERSION}${CMAKE_SHARED_LIBRARY_SUFFIX}")
 endif()
-target_link_libraries(poppler-glib poppler PkgConfig::GLIB2 ${CAIRO_LIBRARIES} Freetype::Freetype)
+target_link_libraries(poppler-glib poppler glib::glib-2.0 glib::gobject-2.0 glib::gio-2.0 cairo::cairo Freetype::Freetype)
 target_include_directories(poppler-glib SYSTEM PRIVATE ${CAIRO_INCLUDE_DIRS})
 install(TARGETS poppler-glib RUNTIME DESTINATION bin LIBRARY DESTINATION ${CMAKE_INSTALL_LIBDIR} ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR})
 
-- 
